# Google AI (Gemini) — required for all AI flows (pitch/buyer/styles/brand agents)
GEMINI_API_KEY=

# Firebase Admin — Firestore for tenants, voice pages, leads, claims, rate limits.
# On Google Cloud / Firebase App Hosting the ambient service account is used
# automatically. Locally, point GOOGLE_APPLICATION_CREDENTIALS at a service
# account JSON, or set the standard Firebase Admin env.
GOOGLE_APPLICATION_CREDENTIALS=
# On Vercel (no ambient GCP service account): paste the full service-account
# JSON as a single-line value here instead of a file path.
FIREBASE_SERVICE_ACCOUNT_KEY=
# Recommended on any host so the project is never mis-detected:
GOOGLE_CLOUD_PROJECT=thinking-prism-495619-u8

# Optional: the primary host, so middleware treats it as an app host (not a
# connected customer domain). e.g. entrestate.com
NEXT_PUBLIC_PRIMARY_HOST=

# Optional rate-limit / quota knobs (defaults shown)
WL_PROVISION_IP_HOURLY=6
WL_SELLER_TURNS_IP_10MIN=40
WL_BUYER_TURNS_IP_10MIN=60
WL_BUYER_TURNS_PAGE_DAILY=1000
WL_STYLES_IP_HOURLY=10
WL_TRACK_IP_10MIN=120
WL_OWNER_TURNS_MONTHLY=0

# ── Voice (kloom) ────────────────────────────────────────────────────────────
# The white-label calls use kloom (deployed on the same Vercel team) as the
# hosted voice service: ElevenLabs TTS (Arabic-tuned) + Groq/Whisper STT.
# Set the provider flag AND point at kloom's deployment to enable it; unset =
# browser Web Speech API.
NEXT_PUBLIC_VOICE_PROVIDER=kloom            # 'kloom' | (unset = browser)
KLOOM_VOICE_BASE_URL=                       # e.g. https://kloom.vercel.app
KLOOM_VOICE_TOKEN=                          # optional bearer if kloom gates its voice API
#
# NOTE: the actual voice-provider keys live in KLOOM's own deployment, not here:
#   TTS  — ELEVENLABS_API_KEY (+ ELEVENLABS_VOICE_MALE/_FEMALE/_FEMALE_SA,
#          ELEVENLABS_MODEL, ELEVENLABS_STABILITY_AR, ELEVENLABS_STYLE_AR …)
#          fallbacks: FAL_KEY+SESAME_TTS, COSYVOICE_*, FISH_API_KEY
#   STT  — GROQ_API_KEY (+ GROQ_STT_MODEL_AR), RUNPOD_STT_ENDPOINT_ID, STT_BASE_URL
#   TURN — TURN_URL/USERNAME/CREDENTIAL, TWILIO_ACCOUNT_SID/AUTH_TOKEN, METERED_API_KEY
# This app only needs the three vars above; it proxies to kloom for the rest.
