rules_version = '2';

// Every read/write in this app goes through Firebase Admin on the server, which
// bypasses these rules. No client SDK touches Firestore directly, so client
// access is denied by default. When the account/studio layer adds client reads,
// tighten per-collection here instead of opening this up.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
